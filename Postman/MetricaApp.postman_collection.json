              "raw": "{\n  \"email\": \"{{emailUser}}\",\n  \"password\": \"{{passwordUser}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Respuesta contiene token', function () {",
                  "  pm.expect(data).to.have.property('token');",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Pedidos (Admin)",
      "item": [
        {
          "name": "GET Pedidos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "pedidos"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Retorna arreglo', function () {",
                  "  pm.expect(data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Crear Pedido",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var uniqueNumber = 'PED-POSTMAN-' + Date.now();",
                  "pm.collectionVariables.set('numeroPedido', uniqueNumber);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Retorna pedido creado con id', function () {",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.collectionVariables.set('pedidoId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cliente\": \"Cliente Postman\",\n  \"estado\": \"Registrado\",\n  \"fecha\": \"2026-03-25T10:00:00Z\",\n  \"numeroPedido\": \"{{numeroPedido}}\",\n  \"total\": 123.45\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "pedidos"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET Pedido por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pedidos/{{pedidoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "pedidos",
                "{{pedidoId}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Id coincide con pedidoId', function () {",
                  "  pm.expect(String(data.id)).to.eql(String(pm.collectionVariables.get('pedidoId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Editar Pedido",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cliente\": \"Cliente Postman Editado\",\n  \"estado\": \"Enviado\",\n  \"fecha\": \"2026-03-25T11:00:00Z\",\n  \"numeroPedido\": \"{{numeroPedido}}\",\n  \"total\": 150.90\n}"
            },
