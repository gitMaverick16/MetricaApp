            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Pedido actualizado', function () {",
                  "  pm.expect(data.cliente).to.eql('Cliente Postman Editado');",
                  "  pm.expect(data.estado).to.eql('Enviado');",
                  "});"
                ]
              }
            }
          ]
        },
