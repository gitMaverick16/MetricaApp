{
  "info": {
    "_postman_id": "3de69f95-9a6b-4ecf-b627-53f131c5d798",
    "name": "MetricaApp - Auth + Pedidos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para probar autenticacion JWT y CRUD de pedidos en MetricaApp."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin (usuario con permisos CRUD)",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{emailAdmin}}\",\n  \"password\": \"{{passwordAdmin}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "pm.test('Respuesta contiene token', function () {",
                  "  pm.expect(data).to.have.property('token');",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(data).to.have.property('expiresIn');",
                  "});",
                  "",
                  "pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User (este usuario recibira 403 en pedidos)",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
